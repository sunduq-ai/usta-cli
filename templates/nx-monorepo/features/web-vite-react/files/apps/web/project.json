{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/web", "command": "pnpm dev" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/web", "command": "pnpm build" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/web", "command": "pnpm test" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/web", "command": "pnpm lint" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/web", "command": "pnpm typecheck" }
    }
  }
}
