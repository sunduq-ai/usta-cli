{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/api",
        "command": "uv run uvicorn src.main:app --reload --port 8000"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/api", "command": "uv build" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/api", "command": "uv run pytest" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/api", "command": "uv run ruff check" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/api", "command": "uv run mypy src" }
    }
  }
}
